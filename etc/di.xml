    <type name="Panth\AdvancedSEO\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Panth\AdvancedSEO\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">panth_seo</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Panth\AdvancedSEO\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

