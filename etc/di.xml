    <!--
        Suppress Magento native category / product canonical emission whenever
        Panth_AdvancedSEO owns canonical output. Prevents duplicate
        <link rel="canonical"> tags when an admin flips
        catalog/seo/category_canonical_tag or catalog/seo/product_canonical_tag
        to 1 without disabling Panth canonical. The runtime guard is a
        transparent after-plugin on canUseCanonicalTag() - no admin UI change.
    -->
    <type name="Magento\Catalog\Helper\Category">
        <plugin name="panth_seo_suppress_native_category_canonical"
                type="Panth\AdvancedSEO\Plugin\Catalog\Canonical\NativeCanonicalSuppressor"
                sortOrder="10"/>
    </type>
    <type name="Magento\Catalog\Helper\Product">
        <plugin name="panth_seo_suppress_native_product_canonical"
                type="Panth\AdvancedSEO\Plugin\Catalog\Canonical\NativeCanonicalSuppressor"
                sortOrder="10"/>
    </type>

