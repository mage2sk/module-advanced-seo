<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- ============================================================ -->
    <!-- panth_seo_template                                             -->
    <!-- ============================================================ -->
    <table name="panth_seo_template" resource="default" engine="innodb" comment="Panth SEO Meta Templates">
        <column xsi:type="int" name="template_id" unsigned="true" nullable="false" identity="true" comment="Template ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type: product|category|cms|other"/>
        <column xsi:type="varchar" name="scope" length="64" nullable="false" default="default" comment="Sub-scope (e.g. attribute set code)"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false" comment="Template name"/>
        <column xsi:type="varchar" name="meta_title" length="512" nullable="true" comment="Meta title pattern"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta description pattern"/>
        <column xsi:type="varchar" name="meta_keywords" length="512" nullable="true" comment="Meta keywords pattern"/>
        <column xsi:type="varchar" name="seo_name" length="512" nullable="true" comment="SEO Name pattern"/>
        <column xsi:type="varchar" name="og_title" length="512" nullable="true" comment="OG title"/>
        <column xsi:type="text" name="og_description" nullable="true" comment="OG description"/>
        <column xsi:type="varchar" name="og_image" length="512" nullable="true" comment="OG image"/>
        <column xsi:type="varchar" name="twitter_card" length="32" nullable="true" comment="Twitter card type"/>
        <column xsi:type="varchar" name="robots" length="64" nullable="true" comment="Robots directive"/>
        <column xsi:type="int" name="priority" unsigned="true" nullable="false" default="10" comment="Priority"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Active"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created at"/>
        <column xsi:type="mediumtext" name="conditions_serialized" nullable="true" comment="Serialized conditions for template matching"/>
        <column xsi:type="varchar" name="url_key_template" length="512" nullable="true" comment="URL key template pattern"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <column xsi:type="boolean" name="is_cron_enabled" nullable="false" default="false" comment="Enable cron auto-apply"/>
        <column xsi:type="timestamp" name="last_applied_at" on_update="false" nullable="true" comment="Last cron application timestamp"/>
        <column xsi:type="int" name="apply_count" unsigned="true" nullable="false" default="0" comment="Number of cron applications"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="template_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_TEMPLATE_STORE_ID_STORE_STORE_ID"
                    table="panth_seo_template" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_SEO_TEMPLATE_IDX_STORE_ENTITY" indexType="btree">
            <column name="store_id"/>
            <column name="entity_type"/>
            <column name="scope"/>
            <column name="is_active"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_override                                             -->
    <!-- ============================================================ -->
    <table name="panth_seo_override" resource="default" engine="innodb" comment="Per-entity SEO overrides">
        <column xsi:type="int" name="override_id" unsigned="true" nullable="false" identity="true" comment="Override ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID"/>
        <column xsi:type="varchar" name="meta_title" length="512" nullable="true" comment="Meta title override"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta description override"/>
        <column xsi:type="varchar" name="meta_keywords" length="512" nullable="true" comment="Meta keywords override"/>
        <column xsi:type="varchar" name="canonical_url" length="1024" nullable="true" comment="Canonical URL override"/>
        <column xsi:type="varchar" name="robots" length="64" nullable="true" comment="Robots override"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created at"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <column xsi:type="varchar" name="hreflang_identifier" length="255" nullable="true" comment="Hreflang identifier for cross-store linking"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="override_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_OVERRIDE_UNQ_STORE_ENTITY">
            <column name="store_id"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_OVERRIDE_STORE_ID_STORE_STORE_ID"
                    table="panth_seo_override" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_resolved                                             -->
    <!-- ============================================================ -->
    <table name="panth_seo_resolved" resource="default" engine="innodb" comment="Indexer output: resolved meta">
        <column xsi:type="int" name="resolved_id" unsigned="true" nullable="false" identity="true" comment="Resolved ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID"/>
        <column xsi:type="varchar" name="meta_title" length="512" nullable="true" comment="Meta title"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta description"/>
        <column xsi:type="varchar" name="meta_keywords" length="512" nullable="true" comment="Meta keywords"/>
        <column xsi:type="varchar" name="canonical_url" length="1024" nullable="true" comment="Canonical URL"/>
        <column xsi:type="varchar" name="robots" length="64" nullable="true" comment="Robots"/>
        <column xsi:type="text" name="og_payload" nullable="true" comment="OG JSON payload"/>
        <column xsi:type="mediumtext" name="jsonld_payload" nullable="true" comment="JSON-LD payload"/>
        <column xsi:type="text" name="hreflang_payload" nullable="true" comment="Hreflang JSON payload"/>
        <column xsi:type="varchar" name="source" length="32" nullable="false" default="template" comment="Source: override|rule|template|fallback"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="resolved_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_RESOLVED_UNQ_STORE_ENTITY">
            <column name="store_id"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
        </constraint>
        <index referenceId="PANTH_SEO_RESOLVED_IDX_TYPE_ID" indexType="btree">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_hreflang_group / _member                             -->
    <!-- ============================================================ -->
    <table name="panth_seo_hreflang_group" resource="default" engine="innodb" comment="Hreflang groups">
        <column xsi:type="int" name="group_id" unsigned="true" nullable="false" identity="true" comment="Group ID"/>
        <column xsi:type="varchar" name="code" length="64" nullable="false" comment="Group code"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Notes"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Active"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created at"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="group_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_HREFLANG_GROUP_UNQ_CODE">
            <column name="code"/>
        </constraint>
    </table>

    <table name="panth_seo_hreflang_member" resource="default" engine="innodb" comment="Hreflang group members">
        <column xsi:type="int" name="member_id" unsigned="true" nullable="false" identity="true" comment="Member ID"/>
        <column xsi:type="int" name="group_id" unsigned="true" nullable="false" comment="Group ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID"/>
        <column xsi:type="varchar" name="locale" length="16" nullable="false" comment="Locale tag (e.g. en-US, x-default)"/>
        <column xsi:type="varchar" name="url" length="1024" nullable="false" comment="Alternate URL"/>
        <column xsi:type="boolean" name="is_default" nullable="false" default="false" comment="x-default flag"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="member_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_HREFLANG_MEMBER_GROUP_ID"
                    table="panth_seo_hreflang_member" column="group_id"
                    referenceTable="panth_seo_hreflang_group" referenceColumn="group_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_HREFLANG_MEMBER_STORE_ID"
                    table="panth_seo_hreflang_member" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_SEO_HREFLANG_MEMBER_IDX_ENTITY" indexType="btree">
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="store_id"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_rule                                                 -->
    <!-- ============================================================ -->
    <table name="panth_seo_rule" resource="default" engine="innodb" comment="SEO Rules">
        <column xsi:type="int" name="rule_id" unsigned="true" nullable="false" identity="true" comment="Rule ID"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false" comment="Name"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="int" name="priority" unsigned="true" nullable="false" default="10" comment="Priority"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Active"/>
        <column xsi:type="boolean" name="stop_on_match" nullable="false" default="false" comment="Stop processing subsequent rules"/>
        <column xsi:type="mediumtext" name="conditions_serialized" nullable="false" comment="Serialized conditions combine"/>
        <column xsi:type="mediumtext" name="actions_serialized" nullable="false" comment="Serialized actions"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created at"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="rule_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_RULE_STORE_ID_STORE_STORE_ID"
                    table="panth_seo_rule" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_SEO_RULE_IDX_STORE_ACTIVE" indexType="btree">
            <column name="store_id"/>
            <column name="is_active"/>
            <column name="priority"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_score                                                -->
    <!-- ============================================================ -->
    <table name="panth_seo_score" resource="default" engine="innodb" comment="SEO Scores">
        <column xsi:type="int" name="score_id" unsigned="true" nullable="false" identity="true" comment="Score ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID"/>
        <column xsi:type="smallint" name="score" unsigned="true" nullable="false" default="0" comment="Score 0-100"/>
        <column xsi:type="varchar" name="grade" length="2" nullable="false" default="F" comment="Grade A-F"/>
        <column xsi:type="text" name="breakdown" nullable="true" comment="JSON breakdown per check"/>
        <column xsi:type="text" name="issues" nullable="true" comment="JSON issues list"/>
        <column xsi:type="timestamp" name="computed_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Computed at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="score_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_SCORE_UNQ_STORE_ENTITY">
            <column name="store_id"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
        </constraint>
        <index referenceId="PANTH_SEO_SCORE_IDX_GRADE" indexType="btree">
            <column name="grade"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_meta_embedding                                       -->
    <!-- ============================================================ -->
    <table name="panth_seo_meta_embedding" resource="default" engine="innodb" comment="Meta text embeddings">
        <column xsi:type="int" name="embedding_id" unsigned="true" nullable="false" identity="true" comment="Embedding ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="entity_type" length="32" nullable="false" comment="Entity type"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="Entity ID"/>
        <column xsi:type="varchar" name="field" length="32" nullable="false" comment="Field: title|description"/>
        <column xsi:type="varchar" name="hash" length="64" nullable="false" comment="Content hash"/>
        <column xsi:type="blob" name="vector" nullable="false" comment="Packed float32 vector"/>
        <column xsi:type="smallint" name="dimensions" unsigned="true" nullable="false" default="384" comment="Vector dimensions"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="embedding_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_EMBED_UNQ_STORE_ENTITY_FIELD">
            <column name="store_id"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="field"/>
        </constraint>
        <index referenceId="PANTH_SEO_EMBED_IDX_HASH" indexType="btree">
            <column name="hash"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_duplicate                                            -->
    <!-- ============================================================ -->
    <table name="panth_seo_duplicate" resource="default" engine="innodb" comment="Detected duplicate meta groups">
        <column xsi:type="int" name="duplicate_id" unsigned="true" nullable="false" identity="true" comment="Duplicate ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="field" length="32" nullable="false" comment="Field"/>
        <column xsi:type="varchar" name="hash" length="64" nullable="false" comment="Content hash"/>
        <column xsi:type="int" name="count" unsigned="true" nullable="false" default="0" comment="Duplicate count"/>
        <column xsi:type="text" name="sample_entities" nullable="true" comment="JSON sample entities"/>
        <column xsi:type="timestamp" name="detected_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Detected at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="duplicate_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_DUPLICATE_UNQ_STORE_FIELD_HASH">
            <column name="store_id"/>
            <column name="field"/>
            <column name="hash"/>
        </constraint>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_filter_rewrite                                       -->
    <!-- ============================================================ -->
    <table name="panth_seo_filter_rewrite" resource="default" engine="innodb" comment="Panth SEO Filter URL Rewrites">
        <column xsi:type="int" name="rewrite_id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="varchar" name="attribute_code" length="255" nullable="false"/>
        <column xsi:type="int" name="option_id" unsigned="true" nullable="false"/>
        <column xsi:type="varchar" name="option_label" length="255" nullable="false"/>
        <column xsi:type="varchar" name="rewrite_slug" length="255" nullable="false"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="rewrite_id"/></constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_FILTER_REWRITE_UNQ"><column name="attribute_code"/><column name="option_id"/><column name="store_id"/></constraint>
        <index referenceId="PANTH_SEO_FILTER_REWRITE_IDX_STORE"><column name="store_id"/></index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_custom_canonical                                     -->
    <!-- ============================================================ -->
    <table name="panth_seo_custom_canonical" resource="default" engine="innodb" comment="Panth SEO Custom Canonical URLs">
        <column xsi:type="int" name="canonical_id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="varchar" name="source_entity_type" length="32" nullable="false"/>
        <column xsi:type="int" name="source_entity_id" unsigned="true" nullable="false"/>
        <column xsi:type="varchar" name="target_url" length="512" nullable="true"/>
        <column xsi:type="varchar" name="target_entity_type" length="32" nullable="true"/>
        <column xsi:type="int" name="target_entity_id" unsigned="true" nullable="true"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="canonical_id"/></constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_CUSTOM_CANONICAL_UNQ"><column name="source_entity_type"/><column name="source_entity_id"/><column name="store_id"/></constraint>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_category_filter_meta                                 -->
    <!-- ============================================================ -->
    <table name="panth_seo_category_filter_meta" resource="default" engine="innodb" comment="Panth SEO Category Filter Meta">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="int" name="category_id" unsigned="true" nullable="false"/>
        <column xsi:type="varchar" name="attribute_code" length="255" nullable="false"/>
        <column xsi:type="int" name="option_id" unsigned="true" nullable="false"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0"/>
        <column xsi:type="varchar" name="meta_title" length="512" nullable="true"/>
        <column xsi:type="text" name="meta_description" nullable="true"/>
        <column xsi:type="varchar" name="meta_keywords" length="512" nullable="true"/>
        <column xsi:type="int" name="breadcrumbs_priority" unsigned="false" nullable="false" default="0" comment="Breadcrumb priority weight"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="id"/></constraint>
        <constraint xsi:type="unique" referenceId="PANTH_SEO_CAT_FILTER_META_UNQ"><column name="category_id"/><column name="attribute_code"/><column name="option_id"/><column name="store_id"/></constraint>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_crawl_result                                         -->
    <!-- ============================================================ -->
    <table name="panth_seo_crawl_result" resource="default" engine="innodb" comment="Panth SEO Crawl Audit Results">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="Row ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="url" length="1024" nullable="false" comment="Crawled URL"/>
        <column xsi:type="smallint" name="status_code" unsigned="true" nullable="false" default="0" comment="HTTP status code"/>
        <column xsi:type="varchar" name="meta_title" length="512" nullable="true" comment="Meta title found"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta description found"/>
        <column xsi:type="varchar" name="canonical" length="1024" nullable="true" comment="Canonical URL found"/>
        <column xsi:type="varchar" name="robots" length="64" nullable="true" comment="Robots directive found"/>
        <column xsi:type="mediumtext" name="issues_json" nullable="true" comment="JSON array of detected issues"/>
        <column xsi:type="timestamp" name="crawled_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Crawled at"/>
        <column xsi:type="int" name="job_id" unsigned="true" nullable="true" comment="Crawl job ID"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_SEO_CRAWL_RESULT_STORE_ID_STORE_STORE_ID"
                    table="panth_seo_crawl_result" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_SEO_CRAWL_RESULT_IDX_STORE" indexType="btree">
            <column name="store_id"/>
        </index>
        <index referenceId="PANTH_SEO_CRAWL_RESULT_IDX_JOB" indexType="btree">
            <column name="job_id"/>
        </index>
        <index referenceId="PANTH_SEO_CRAWL_RESULT_IDX_STATUS" indexType="btree">
            <column name="status_code"/>
        </index>
    </table>

    <!-- ============================================================ -->
    <!-- panth_seo_related                                              -->
    <!-- ============================================================ -->
    <table name="panth_seo_related" resource="default" engine="innodb" comment="Panth SEO related / internal linking suggestions">
        <column xsi:type="int" name="related_id" unsigned="true" nullable="false" identity="true" comment="Related ID"/>
        <column xsi:type="varchar" name="source_type" length="32" nullable="false" comment="Source entity type"/>
        <column xsi:type="int" name="source_id" unsigned="true" nullable="false" comment="Source entity ID"/>
        <column xsi:type="varchar" name="target_type" length="32" nullable="false" comment="Target entity type"/>
        <column xsi:type="int" name="target_id" unsigned="true" nullable="false" comment="Target entity ID"/>
        <column xsi:type="decimal" name="score" scale="6" precision="12" nullable="false" default="0" comment="Score"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated at"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="related_id"/>
        </constraint>
        <index referenceId="PANTH_SEO_RELATED_IDX_SOURCE" indexType="btree">
            <column name="source_type"/>
            <column name="source_id"/>
            <column name="store_id"/>
        </index>
        <index referenceId="PANTH_SEO_RELATED_IDX_TARGET" indexType="btree">
