<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Mview/etc/mview.xsd">
    <view id="panth_seo_resolved_meta" class="Panth\AdvancedSEO\Model\Indexer\ResolvedMeta" group="indexer">
        <subscriptions>
            <table name="catalog_product_entity" entity_column="entity_id"/>
            <table name="catalog_category_entity" entity_column="entity_id"/>
            <table name="cataloginventory_stock_item" entity_column="product_id"/>
            <table name="cms_page" entity_column="page_id"/>
        </subscriptions>
    </view>
    <view id="panth_seo_hreflang" class="Panth\AdvancedSEO\Model\Indexer\Hreflang" group="indexer">
        <subscriptions>
            <table name="panth_seo_hreflang_member" entity_column="member_id"/>
            <table name="panth_seo_hreflang_group" entity_column="group_id"/>
        </subscriptions>
    </view>
</config>
