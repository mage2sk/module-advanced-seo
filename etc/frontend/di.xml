<?xml version="1.0"?>
<!--
  Frontend-only DI: these plugins ONLY load on storefront requests.
  They are NEVER instantiated on admin, API, or cron requests.
  This prevents session/form-key issues in the admin panel.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Redirect plugins: MUST be frontend-only to avoid admin session interference -->
    <type name="Magento\Framework\App\FrontControllerInterface">
        <plugin name="panth_seo_homepage_redirect" type="Panth\AdvancedSEO\Plugin\Redirect\HomepageRedirectPlugin" sortOrder="5"/>
        <plugin name="panth_seo_lowercase_redirect" type="Panth\AdvancedSEO\Plugin\Redirect\LowercaseRedirectPlugin" sortOrder="10"/>
        <plugin name="panth_seo_trailing_slash_redirect" type="Panth\AdvancedSEO\Plugin\Redirect\TrailingSlashRedirectPlugin" sortOrder="15"/>
    </type>

    <!-- HTTP header plugins: frontend-only -->
    <type name="Magento\Framework\App\Response\Http">
        <plugin name="panth_seo_x_robots_tag" type="Panth\AdvancedSEO\Plugin\Response\XRobotsTagPlugin" sortOrder="10"/>
        <plugin name="panth_seo_canonical_header" type="Panth\AdvancedSEO\Plugin\Response\CanonicalHeaderPlugin" sortOrder="20"/>
        <plugin name="panth_seo_last_modified_header" type="Panth\AdvancedSEO\Plugin\Response\LastModifiedHeaderPlugin" sortOrder="30"/>
    </type>

    <!-- SEO Toolbar: frontend-only -->
    <type name="Magento\Framework\View\Result\Page">
        <plugin name="panth_seo_seo_toolbar" type="Panth\AdvancedSEO\Plugin\Frontend\SeoToolbarPlugin" sortOrder="10"/>
    </type>

    <!-- 404 logger: intercepts NoRouteHandler to log all 404 requests -->
    <type name="Magento\Framework\App\Router\NoRouteHandler">
        <plugin name="panth_seo_noroute_logger" type="Panth\AdvancedSEO\Plugin\NoRouteLoggerPlugin" sortOrder="100"/>
    </type>

    <!--
        Block Magento core's UrlRewrite router from dispatching 301s on XHR /
        non-GET requests. DbStorage::doFindOneByData() trims trailing slashes
        and matches redirect_type=301 rows BEFORE any of our FrontController
        plugins run, so RedirectGuard never sees the request. This plugin
        short-circuits Router::match() on unsafe requests (XHR, non-GET, API)
        by returning null, letting the request fall through to the natural
        controller. Normal browser GET navigation is unaffected.
    -->
    <type name="Magento\UrlRewrite\Controller\Router">
        <plugin name="panth_seo_url_rewrite_xhr_guard"
                type="Panth\AdvancedSEO\Plugin\UrlRewrite\RouterXhrGuard"
                sortOrder="10"/>
    </type>

    <!--
        Disable Magento core's robots.txt router.

        Magento\Robots\Controller\Router intercepts /robots.txt at the router
        layer (sortOrder 10) and dispatches it to
        Magento\Robots\Controller\Index\Index BEFORE the URL rewrite router
        runs. That short-circuits the url_rewrite rows we install
        (robots.txt -> seo/robots/index), so our per-store controller never
        sees the request. The core controller builds its Sitemap line from
        the design/search_engine_robots/custom_instructions config, which is
        only resolved against the default scope at that point in the stack,
        so https://luma.test/robots.txt was serving
        "Sitemap: https://hyva.test/sitemap.xml" instead of luma.test's URL.

        Disabling this router lets our url_rewrite row route /robots.txt to
        Panth\AdvancedSEO\Controller\Robots\Index, which builds the body via
        StoreManagerInterface->getStore($storeId) for the MAGE_RUN_CODE-
        resolved store and emits the correct per-store Sitemap line.
    -->
    <!--
        Explicit constructor binding for the IndexNow Key controller.
        The RequestInterface argument was added to eliminate a legacy
        ObjectManager::getInstance() lookup; declaring it here guarantees
        the DI compiler will pick it up even if stale interceptors exist
        in the generated/code cache.
    -->
    <type name="Panth\AdvancedSEO\Controller\IndexNow\Key">
        <arguments>
            <argument name="request" xsi:type="object">Magento\Framework\App\RequestInterface</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\App\RouterList">
        <arguments>
            <argument name="routerList" xsi:type="array">
                <item name="robots" xsi:type="array">
                    <item name="disable" xsi:type="boolean">true</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
