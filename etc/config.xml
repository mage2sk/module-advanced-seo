<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <!--
            Force Magento native canonical tag emission OFF at the module
            default level. Panth\AdvancedSEO\Block\Head\Canonical owns the
            canonical URL for category and product pages (with pagination and
            resolver rules). Shipping these defaults at 0 prevents duplicate
            <link rel="canonical"> tags when the module is installed on a
            store that previously had the native catalog/seo/*_canonical_tag
            flags enabled. Runtime suppression is also applied via the
            NativeCanonicalSuppressor plugin as a belt-and-braces safeguard.
        -->
        <catalog>
            <seo>
                <category_canonical_tag>0</category_canonical_tag>
                <product_canonical_tag>0</product_canonical_tag>
            </seo>
        </catalog>
        <panth_seo>
            <general>
                <enabled>1</enabled>
                <debug>0</debug>
            </general>
            <meta>
                <use_templates>1</use_templates>
                <title_max_length>60</title_max_length>
                <description_max_length>160</description_max_length>
                <append_store_name>0</append_store_name>
                <strip_title_prefix_suffix>0</strip_title_prefix_suffix>
                <seo_name_enabled>1</seo_name_enabled>
                <pagination_position>suffix</pagination_position>
                <pagination_format> | Page %p</pagination_format>
                <force_template_over_existing>0</force_template_over_existing>
            </meta>
            <canonical>
                <enabled>1</enabled>
                <strip_query>1</strip_query>
                <lowercase_host>1</lowercase_host>
                <remove_trailing_slash>1</remove_trailing_slash>
                <paginated_canonical_to_first>0</paginated_canonical_to_first>
                <associated_product_canonical>1</associated_product_canonical>
                <cross_domain_store>0</cross_domain_store>
                <canonical_ignore_pages></canonical_ignore_pages>
                <disable_canonical_for_noindex>1</disable_canonical_for_noindex>
                <product_canonical_type>without_category</product_canonical_type>
                <use_short_category_url>0</use_short_category_url>
                <trailing_slash_homepage>none</trailing_slash_homepage>
                <strip_params></strip_params>
            </canonical>
            <social>
                <og_enabled>1</og_enabled>
                <twitter_enabled>1</twitter_enabled>
                <twitter_card_type>summary_large_image</twitter_card_type>
                <twitter_site_handle></twitter_site_handle>
                <default_og_image></default_og_image>
            </social>
            <social_profiles>
                <facebook_url></facebook_url>
                <twitter_url></twitter_url>
                <instagram_url></instagram_url>
                <linkedin_url></linkedin_url>
                <youtube_url></youtube_url>
                <pinterest_url></pinterest_url>
                <tiktok_url></tiktok_url>
            </social_profiles>
            <structured_data>
                <product>1</product>
                <breadcrumb>1</breadcrumb>
                <organization>1</organization>
                <website>1</website>
                <faq>1</faq>
                <article>1</article>
                <review>1</review>
                <video>1</video>
                <brand>1</brand>
                <seller>1</seller>
                <configurable_multi_offer>1</configurable_multi_offer>
                <remove_native_markup>1</remove_native_markup>
                <return_policy_days>30</return_policy_days>
                <brand_attribute>manufacturer</brand_attribute>
                <gtin_attribute></gtin_attribute>
                <mpn_attribute></mpn_attribute>
                <enable_product_list_schema>1</enable_product_list_schema>
                <accepted_payment_methods></accepted_payment_methods>
                <delivery_methods></delivery_methods>
                <product_condition>new</product_condition>
                <price_valid_until_default></price_valid_until_default>
                <custom_properties></custom_properties>
                <product_group_enabled>0</product_group_enabled>
                <pros_cons_enabled>0</pros_cons_enabled>
                <pros_attribute>product_pros</pros_attribute>
                <cons_attribute>product_cons</cons_attribute>
                <energy_label_enabled>0</energy_label_enabled>
                <energy_class_attribute>energy_class</energy_class_attribute>
                <certification_enabled>0</certification_enabled>
                <certification_attribute>certifications</certification_attribute>
                <sale_event_enabled>1</sale_event_enabled>
                <business_type>Organization</business_type>
                <default_brand></default_brand>
                <return_policy_type>refund</return_policy_type>
                <return_policy_fees>free</return_policy_fees>
            </structured_data>
            <organization>
                <legal_name></legal_name>
                <logo></logo>
                <phone></phone>
                <email></email>
                <street></street>
                <locality></locality>
                <region></region>
                <postcode></postcode>
                <country></country>
                <same_as></same_as>
            </organization>
            <url>
                <auto_url_key_enabled>0</auto_url_key_enabled>
                <url_key_template>{{name}}</url_key_template>
                <auto_url_key_for_existing>0</auto_url_key_for_existing>
            </url>
            <filter_urls>
                <filter_urls_enabled>0</filter_urls_enabled>
                <url_format>short</url_format>
                <separator>-</separator>
            </filter_urls>
            <filter_meta>
                <filter_meta_enabled>0</filter_meta_enabled>
                <inject_filter_in_title>1</inject_filter_in_title>
                <inject_filter_in_description>1</inject_filter_in_description>
            </filter_meta>
            <breadcrumbs>
                <enable_breadcrumb_priority>0</enable_breadcrumb_priority>
                <breadcrumb_format>longest</breadcrumb_format>
            </breadcrumbs>
            <sitemap>
                <enabled>1</enabled>
                <shard_size>45000</shard_size>
                <gzip>1</gzip>
                <include_images>1</include_images>
                <include_hreflang>1</include_hreflang>
                <include_video>0</include_video>
                <exclude_out_of_stock>1</exclude_out_of_stock>
                <exclude_noindex>1</exclude_noindex>
                <additional_links></additional_links>
                <xsl_enabled>1</xsl_enabled>
                <ping_google>1</ping_google>
                <ping_bing>1</ping_bing>
                <additional_links_changefreq>weekly</additional_links_changefreq>
                <additional_links_priority>0.5</additional_links_priority>
                <product_image_source>base_image</product_image_source>
                <homepage_optimization>1</homepage_optimization>
            </sitemap>
            <hreflang>
                <enabled>1</enabled>
                <emit_x_default>1</emit_x_default>
                <hreflang_scope>website</hreflang_scope>
                <cms_relation_method>by_url_key</cms_relation_method>
            </hreflang>
            <reports>
                <enable_crawl_audit>0</enable_crawl_audit>
                <crawl_depth>100</crawl_depth>
                <seo_toolbar_enabled>0</seo_toolbar_enabled>
                <seo_toolbar_allowed_ips></seo_toolbar_allowed_ips>
            </reports>
            <image>
                <image_seo_enabled>1</image_seo_enabled>
                <alt_template>{{name}} - {{store}}</alt_template>
                <title_template>{{name}}</title_template>
                <gallery_seo_enabled>1</gallery_seo_enabled>
            </image>
            <indexnow>
                <enabled>0</enabled>
                <api_key/>
            </indexnow>
            <llms_txt>
                <enabled>1</enabled>
                <summary></summary>
                <max_categories>20</max_categories>
                <max_products>50</max_products>
                <max_cms>10</max_cms>
                <generate_full_llms>0</generate_full_llms>
                <shipping_page></shipping_page>
                <returns_page></returns_page>
                <about_page></about_page>
                <faq_page></faq_page>
            </llms_txt>
            <merchant_feed>
                <enabled>0</enabled>
                <include_out_of_stock>0</include_out_of_stock>
                <default_condition>new</default_condition>
                <google_category_attribute></google_category_attribute>
                <shipping_country></shipping_country>
                <shipping_price></shipping_price>
            </merchant_feed>
            <analytics>
                <ga4_enabled>0</ga4_enabled>
                <ga4_measurement_id/>
                <ga4_enhanced_ecommerce>1</ga4_enhanced_ecommerce>
            </analytics>
            <search_console>
                <indexing_api_enabled>0</indexing_api_enabled>
                <service_account_json/>
                <site_verification_code/>
            </search_console>
            <advanced>
                <async_indexing>1</async_indexing>
                <mview_enabled>1</mview_enabled>
                <last_modified_header>1</last_modified_header>
                <speculation_rules_enabled>0</speculation_rules_enabled>
            </advanced>
        </panth_seo>
    </default>
</config>
