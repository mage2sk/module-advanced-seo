<?php
/**
 * Panth SEO Toolbar -- floating diagnostic drawer.
 *
 * Rendered by \Panth\AdvancedSEO\Plugin\Frontend\SeoToolbarPlugin via a
 * scoped include, NOT by Magento's layout system, so the following two
 * locals are provided by the caller:
 *
 * @var array<string,mixed> $data    Payload from SeoToolbar::getData()
 * @var \Panth\AdvancedSEO\Plugin\Frontend\SeoToolbarPlugin $helper
 *
 * All output is escaped via $helper->esc() / $helper->escJson() which delegate
 * to htmlspecialchars(). The MEQP sniffer does not recognise these as safe, so
 * every short-echo tag carries a @noEscape annotation.
 *
 * The entire markup -- CSS, HTML, JS -- is inlined so the toolbar works on
 * Hyva (Alpine) and Luma (RequireJS) without any module loader. All values
 * are escaped with $helper->esc() before reaching the DOM. JSON-LD blocks
 * and the page-state dataset are passed to JS via a <script type="application/json">
 * element (NOT eval, NOT inline literal) and read back via textContent.
 */

// ---------------------------------------------------------------------------
// Normalise data
// ---------------------------------------------------------------------------
$identity     = is_array($data['identity'] ?? null) ? $data['identity'] : [];
$meta         = is_array($data['meta'] ?? null) ? $data['meta'] : [];
$ogTags       = is_array($data['og_tags'] ?? null) ? $data['og_tags'] : [];
$twitterTags  = is_array($data['twitter_tags'] ?? null) ? $data['twitter_tags'] : [];
$hreflang     = is_array($data['hreflang'] ?? null) ? $data['hreflang'] : [];
$jsonldBlocks = is_array($data['jsonld'] ?? null) ? $data['jsonld'] : [];
$jsonldWarns  = is_array($data['jsonld_warnings'] ?? null) ? $data['jsonld_warnings'] : [];
$headers      = is_array($data['headers'] ?? null) ? $data['headers'] : [];
$cookies      = is_array($data['cookies'] ?? null) ? $data['cookies'] : [];
$score        = is_array($data['score'] ?? null) ? $data['score'] : null;

$title        = (string) ($meta['title'] ?? '');
$titleLen     = (int)    ($meta['title_length'] ?? 0);
$desc         = (string) ($meta['description'] ?? '');
$descLen      = (int)    ($meta['description_length'] ?? 0);
$canonical    = (string) ($meta['canonical'] ?? '');
$robots       = (string) ($meta['robots'] ?? '');
$keywords     = (string) ($meta['keywords'] ?? '');
$baseUrl      = (string) ($meta['base_url'] ?? '');

$titleStatus  = $helper->statusClass($titleLen, 30, 60);
$descStatus   = $helper->statusClass($descLen, 70, 160);
$titlePct     = max(0, min(100, (int) round($titleLen / 60 * 100)));
$descPct      = max(0, min(100, (int) round($descLen / 160 * 100)));

$scoreValue = $score !== null ? (int) ($score['score'] ?? 0) : -1;
$scoreGrade = $score !== null ? (string) ($score['grade'] ?? 'F') : '';
$scoreDeg   = max(0, min(360, (int) round($scoreValue / 100 * 360)));
$scoreClass = 'g';
if ($scoreValue >= 0 && $scoreValue < 50) {
    $scoreClass = 'r';
} elseif ($scoreValue >= 50 && $scoreValue < 80) {
    $scoreClass = 'y';
}

$robotsClass = 'g';
$robotsLc = strtolower($robots);
if (str_contains($robotsLc, 'noindex')) {
    $robotsClass = 'y';
}
if (str_contains($robotsLc, 'none')) {
    $robotsClass = 'r';
}

// JSON-LD type list (for the header badge)
$jsonldTypeList = [];
foreach ($jsonldBlocks as $blk) {
    if (isset($blk['types']) && is_array($blk['types'])) {
        foreach ($blk['types'] as $t) {
            $jsonldTypeList[] = (string) $t;
        }
    }
}
$jsonldTypeList = array_values(array_unique($jsonldTypeList));
?>
