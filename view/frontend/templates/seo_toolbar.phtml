          <button type="button" class="pseo-action" data-action="copyCanonical">Copy canonical</button>
          <button type="button" class="pseo-action" data-action="viewSource">View source</button>
          <button type="button" class="pseo-action" data-action="richResults">Rich Results</button>
          <button type="button" class="pseo-action" data-action="ogDebug">OG debug</button>
          <button type="button" class="pseo-action" data-action="twitterDebug">Twitter</button>
          <button type="button" class="pseo-action pseo-primary" data-action="refresh">Refresh</button>
