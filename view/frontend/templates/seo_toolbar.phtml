<div class="pseo-toast" id="pseo-toast" role="status" aria-live="polite"></div>

<script>
(function(){
  "use strict";
  var STORAGE_KEY="pseo.toolbar.v2";
  var root=document.getElementById("pseo-toolbar");
  if(!root)return;
  var badge=document.getElementById("pseo-badge");
  var panel=document.getElementById("pseo-panel");
  var closeBtn=document.getElementById("pseo-close");
  var refreshBtn=document.getElementById("pseo-refresh");
  var dragHead=document.getElementById("pseo-drag");
  var resize=document.getElementById("pseo-resize");
  var toast=document.getElementById("pseo-toast");
  if(!badge||!panel)return;

  function loadState(){
    try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||"{}")||{};}
    catch(e){return{};}
  }
  function saveState(s){
    try{localStorage.setItem(STORAGE_KEY,JSON.stringify(s||{}));}catch(e){}
  }
  var state=loadState();

  function showToast(msg,color){
    if(!toast)return;
    toast.textContent=msg;
    toast.style.color=color||"var(--pseo-g)";
    toast.classList.add("pseo-visible");
    clearTimeout(toast._t);
    toast._t=setTimeout(function(){toast.classList.remove("pseo-visible");},1600);
  }

  // ---------- expand / collapse ----------
  function open(){
    panel.classList.add("pseo-visible");
    panel.setAttribute("aria-hidden","false");
    badge.setAttribute("aria-expanded","true");
    badge.style.display="none";
    state.open=true;saveState(state);
    setTimeout(runClientMetrics,0);
  }
  function collapse(){
    panel.classList.remove("pseo-visible");
    panel.setAttribute("aria-hidden","true");
    badge.setAttribute("aria-expanded","false");
    badge.style.display="";
    state.open=false;saveState(state);
  }
  badge.addEventListener("click",open);
  badge.addEventListener("keydown",function(e){
    if(e.key==="Enter"||e.key===" "){e.preventDefault();open();}
  });
  if(closeBtn)closeBtn.addEventListener("click",collapse);

  // ---------- keyboard shortcut ----------
  document.addEventListener("keydown",function(e){
    if((e.ctrlKey||e.metaKey)&&e.shiftKey&&(e.key==="S"||e.key==="s")){
      e.preventDefault();
      if(panel.classList.contains("pseo-visible"))collapse();else open();
    }
  });

  // ---------- restore state ----------
  if(state.x!==undefined&&state.y!==undefined){
    panel.style.right="auto";panel.style.bottom="auto";
    panel.style.left=state.x+"px";panel.style.top=state.y+"px";
  }
  if(state.w)panel.style.width=state.w+"px";
  if(state.h)panel.style.height=state.h+"px";
  if(state.open)open();

  // ---------- section collapse ----------
  var sections=panel.querySelectorAll(".pseo-section");
  sections.forEach(function(sec){
    var head=sec.querySelector(".pseo-section-head");
    if(!head)return;
    head.addEventListener("click",function(){
      var isOpen=sec.getAttribute("data-open")==="true";
      sec.setAttribute("data-open",isOpen?"false":"true");
      head.setAttribute("aria-expanded",isOpen?"false":"true");
    });
  });

  // JSON-LD block expand
  panel.querySelectorAll(".pseo-jsonld-block").forEach(function(blk){
    var head=blk.querySelector(".pseo-jsonld-head");
    if(!head)return;
    head.addEventListener("click",function(){
      var o=blk.getAttribute("data-open")==="true";
      blk.setAttribute("data-open",o?"false":"true");
      head.setAttribute("aria-expanded",o?"false":"true");
      var json=blk.querySelector(".pseo-json");
      if(json)json.style.display=o?"none":"block";
    });
  });

  // ---------- copy buttons ----------
  function copyText(text){
    if(!text)return Promise.reject();
    if(navigator.clipboard&&navigator.clipboard.writeText){
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function(res,rej){
      try{
        var ta=document.createElement("textarea");
        ta.value=text;ta.style.position="fixed";ta.style.opacity="0";
        document.body.appendChild(ta);ta.select();
        document.execCommand("copy");document.body.removeChild(ta);res();
      }catch(e){rej(e);}
    });
  }
  panel.querySelectorAll(".pseo-copy").forEach(function(btn){
    btn.addEventListener("click",function(e){
      e.stopPropagation();
      var v=btn.getAttribute("data-copy-val")||"";
      copyText(v).then(function(){showToast("Copied");},function(){showToast("Copy failed","var(--pseo-r)");});
    });
  });

  // ---------- quick actions ----------
  var TITLE=<?= /* @noEscape */ json_encode($title, JSON_HEX_TAG|JSON_HEX_AMP|JSON_HEX_APOS|JSON_HEX_QUOT|JSON_UNESCAPED_SLASHES) ?>;
  var CANONICAL=<?= /* @noEscape */ json_encode($canonical, JSON_HEX_TAG|JSON_HEX_AMP|JSON_HEX_APOS|JSON_HEX_QUOT|JSON_UNESCAPED_SLASHES) ?>;
  panel.querySelectorAll(".pseo-action").forEach(function(btn){
    btn.addEventListener("click",function(){
      var act=btn.getAttribute("data-action");
      var url=window.location.href;
      if(act==="copyTitle"){copyText(TITLE||document.title).then(function(){showToast("Title copied");});}
      else if(act==="copyCanonical"){copyText(CANONICAL||url).then(function(){showToast("Canonical copied");});}
      else if(act==="viewSource"){
        // Browsers block JS from navigating to view-source: URLs (only the
        // address bar can). We instead grab the current document's outerHTML
        // (no extra HTTP request, no auth issues) and serve it as a Blob in
        // a new tab. The blob is text/plain so the browser shows it raw.
        try{
          var src=("<!doctype html>\n"+(document.documentElement&&document.documentElement.outerHTML?document.documentElement.outerHTML:""));
          if(window.URL&&window.Blob){
            var blob=new Blob([src],{type:"text/plain;charset=utf-8"});
            var blobUrl=URL.createObjectURL(blob);
            var w=window.open(blobUrl,"_blank","noopener,noreferrer");
            if(!w){showToast("Pop-up blocked");}
            // Free the blob URL after a minute so it does not leak.
            setTimeout(function(){try{URL.revokeObjectURL(blobUrl);}catch(_e){}},60000);
          } else {
            // Last-resort fallback for ancient browsers
            var w2=window.open("","_blank");
            if(w2){w2.document.open();w2.document.write("<pre>"+src.replace(/[&<>]/g,function(c){return c==="&"?"&amp;":c==="<"?"&lt;":"&gt;";})+"</pre>");w2.document.close();}
            else {showToast("Pop-up blocked");}
          }
        } catch(_e){showToast("View source failed");}
      }
      else if(act==="richResults"){window.open("https://search.google.com/test/rich-results?url="+encodeURIComponent(url),"_blank","noopener,noreferrer");}
      else if(act==="ogDebug"){window.open("https://www.opengraph.xyz/url/"+encodeURIComponent(url),"_blank","noopener,noreferrer");}
      else if(act==="twitterDebug"){window.open("https://cards-dev.twitter.com/validator","_blank","noopener,noreferrer");}
      else if(act==="refresh"){runClientMetrics();showToast("Refreshed");}
    });
  });
  if(refreshBtn)refreshBtn.addEventListener("click",function(){runClientMetrics();showToast("Refreshed");});

  // ---------- drag ----------
  (function(){
    var dragging=false,startX=0,startY=0,origX=0,origY=0;
    dragHead.addEventListener("pointerdown",function(e){
      if(e.target.closest("button"))return;
      dragging=true;
      var r=panel.getBoundingClientRect();
      origX=r.left;origY=r.top;startX=e.clientX;startY=e.clientY;
      panel.style.right="auto";panel.style.bottom="auto";
      panel.style.left=origX+"px";panel.style.top=origY+"px";
      dragHead.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    dragHead.addEventListener("pointermove",function(e){
      if(!dragging)return;
      var nx=origX+(e.clientX-startX);
      var ny=origY+(e.clientY-startY);
      nx=Math.max(0,Math.min(window.innerWidth-80,nx));
      ny=Math.max(0,Math.min(window.innerHeight-40,ny));
      panel.style.left=nx+"px";panel.style.top=ny+"px";
    });
    dragHead.addEventListener("pointerup",function(e){
      if(!dragging)return;
      dragging=false;
      try{dragHead.releasePointerCapture(e.pointerId);}catch(er){}
      var r=panel.getBoundingClientRect();
      state.x=Math.round(r.left);state.y=Math.round(r.top);saveState(state);
    });
  })();

  // ---------- resize (bottom-left handle, grows up/left) ----------
  (function(){
    if(!resize)return;
    var resizing=false,startW=0,startH=0,startX=0,startY=0,origLeft=0,origTop=0;
    resize.addEventListener("pointerdown",function(e){
      resizing=true;
      var r=panel.getBoundingClientRect();
      startW=r.width;startH=r.height;startX=e.clientX;startY=e.clientY;
      origLeft=r.left;origTop=r.top;
      panel.style.right="auto";panel.style.bottom="auto";
      panel.style.left=origLeft+"px";panel.style.top=origTop+"px";
      resize.setPointerCapture(e.pointerId);
      e.preventDefault();e.stopPropagation();
    });
    resize.addEventListener("pointermove",function(e){
      if(!resizing)return;
      var dx=e.clientX-startX;
      var dy=e.clientY-startY;
      var w=Math.max(320,startW-dx);
      var h=Math.max(180,startH+dy);
      panel.style.width=w+"px";panel.style.height=h+"px";
      panel.style.maxHeight="none";
      var newLeft=origLeft+(startW-w);
      panel.style.left=newLeft+"px";
    });
    resize.addEventListener("pointerup",function(e){
      if(!resizing)return;
      resizing=false;
      try{resize.releasePointerCapture(e.pointerId);}catch(er){}
      var r=panel.getBoundingClientRect();
      state.w=Math.round(r.width);state.h=Math.round(r.height);
      state.x=Math.round(r.left);state.y=Math.round(r.top);
      saveState(state);
    });
  })();

  // ---------- client-side metrics ----------
  function setText(key,value,pillClass){
    var nodes=panel.querySelectorAll('[data-js="'+key+'"]');
    nodes.forEach(function(n){
      if(pillClass&&n.classList.contains("pseo-pill")){
        n.classList.remove("pseo-g","pseo-y","pseo-r","pseo-b");
        n.classList.add("pseo-"+pillClass);
      }
      n.textContent=value==null?"--":String(value);
    });
  }
  function fillList(key,items){
    var nodes=panel.querySelectorAll('[data-js="'+key+'"]');
    nodes.forEach(function(ul){
      ul.textContent="";
      if(!items||!items.length){
        var li=document.createElement("li");
        li.className="pseo-muted";li.textContent="(none)";
        ul.appendChild(li);return;
      }
      items.forEach(function(it){
        var li=document.createElement("li");li.className="pseo-mono";
        li.textContent=it;ul.appendChild(li);
      });
    });
  }

  function byText(el){return (el.textContent||"").replace(/\s+/g," ").trim();}

  function runClientMetrics(){
    try{
      // Headings
      var all=document.body.querySelectorAll("h1,h2,h3");
      var h1s=[],h2s=[],h3s=[];
      all.forEach(function(el){
        if(el.closest("#pseo-toolbar"))return;
        var tn=el.tagName;
        if(tn==="H1")h1s.push(byText(el));
        else if(tn==="H2")h2s.push(byText(el));
        else if(tn==="H3")h3s.push(byText(el));
      });
      setText("headingCount",h1s.length+h2s.length+h3s.length);
      setText("h2Count",h2s.length);
      setText("h3Count",h3s.length);
      var h1Status=h1s.length===1?"g":(h1s.length===0?"r":"y");
      setText("h1Pill",h1s.length,h1Status);
      var h1Pill=document.getElementById("pseo-pill-h1");
      if(h1Pill){
        h1Pill.classList.remove("pseo-g","pseo-y","pseo-r","pseo-b");
        h1Pill.classList.add("pseo-"+h1Status);
      }
      var h1Count=document.getElementById("pseo-pill-h1-count");
      if(h1Count)h1Count.textContent=h1s.length;
      fillList("h1List",h1s);
      fillList("h2List",h2s.slice(0,10));

      // Images
      var imgs=document.querySelectorAll("img");
      var total=0,noAlt=0,emptyAlt=0,lazy=0,noAltList=[];
      imgs.forEach(function(img){
        if(img.closest("#pseo-toolbar"))return;
        total++;
        var alt=img.getAttribute("alt");
        if(alt===null)noAlt++;
        else if(alt.trim()==="")emptyAlt++;
        if(img.getAttribute("loading")==="lazy")lazy++;
        if((alt===null||alt.trim()==="")&&noAltList.length<10){
          noAltList.push(img.src||"(no src)");
        }
      });
      setText("imgTotal",total);
      setText("imgTotalVal",total);
      setText("imgNoAlt",noAlt);
      setText("imgEmptyAlt",emptyAlt);
      setText("imgLazy",lazy);
      fillList("imgNoAltList",noAltList);

      // Links
      var links=document.querySelectorAll("a[href]");
      var host=window.location.hostname;
      var iCount=0,iNofollow=0,eCount=0,eNofollow=0,eUnsafe=0;
      links.forEach(function(a){
        if(a.closest("#pseo-toolbar"))return;
        var href=a.getAttribute("href")||"";
        if(!href||href.charAt(0)==="#"||href.indexOf("javascript:")===0||href.indexOf("mailto:")===0||href.indexOf("tel:")===0)return;
        var linkHost="";
        try{linkHost=new URL(a.href,window.location.origin).hostname;}catch(er){return;}
        var rel=(a.getAttribute("rel")||"").toLowerCase();
        var isNofollow=rel.indexOf("nofollow")!==-1;
        if(linkHost===host||linkHost===""){
          iCount++;if(isNofollow)iNofollow++;
        }else{
          eCount++;
          if(isNofollow)eNofollow++;
          if(a.getAttribute("target")==="_blank"&&rel.indexOf("noopener")===-1)eUnsafe++;
        }
      });
      setText("intCount",iCount);setText("intCountVal",iCount);setText("intNofollow",iNofollow);
      setText("extCount",eCount);setText("extCountVal",eCount);setText("extNofollow",eNofollow);
      setText("extUnsafe",eUnsafe);

      // Performance
      var perf=window.performance;
      if(perf&&perf.getEntriesByType){
        var nav=perf.getEntriesByType("navigation")[0];
        if(nav){
          setText("perfDom",Math.round(nav.domContentLoadedEventEnd)+" ms");
          setText("perfLoad",Math.round(nav.loadEventEnd||nav.duration)+" ms");
          if(nav.transferSize)setText("perfSize",Math.round(nav.transferSize/1024)+" KB (transfer)");
          else if(nav.encodedBodySize)setText("perfSize",Math.round(nav.encodedBodySize/1024)+" KB");
        }
      }
      var htmlSize=(document.documentElement.outerHTML||"").length;
      var sizeEl=panel.querySelector('[data-js="perfSize"]');
      if(sizeEl&&sizeEl.textContent==="--")setText("perfSize",Math.round(htmlSize/1024)+" KB (DOM)");
      setText("perfScripts",document.querySelectorAll("script").length);
      setText("perfStyles",document.querySelectorAll('link[rel="stylesheet"],style').length);
      setText("perfImgs",total);
      setText("perfPreconnect",document.querySelectorAll('link[rel="preconnect"]').length);
      setText("perfPreload",document.querySelectorAll('link[rel="preload"]').length);
      var bodyText=(document.body.innerText||"").replace(/\s+/g," ").trim();
      setText("perfWords",bodyText?bodyText.split(" ").length:0);
    }catch(er){}
  }

  // run once at startup
  if(document.readyState==="complete"){setTimeout(runClientMetrics,0);}
  else{window.addEventListener("load",function(){setTimeout(runClientMetrics,0);});}
})();
