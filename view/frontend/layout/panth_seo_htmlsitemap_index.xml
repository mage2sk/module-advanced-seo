<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Panth\AdvancedSEO\Block\Html\Sitemap"
                   name="panth.seo.htmlsitemap"
                   template="Panth_AdvancedSEO::html/sitemap.phtml">
                <arguments>
                    <argument name="html_sitemap" xsi:type="object">Panth\AdvancedSEO\ViewModel\HtmlSitemap</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
