<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_seo_filterrewrite_form.panth_seo_filterrewrite_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="delete" class="Panth\AdvancedSEO\Block\Adminhtml\GenericDeleteButton"/>
            <button name="save_and_continue" class="Panth\AdvancedSEO\Block\Adminhtml\GenericSaveAndContinueButton"/>
            <button name="save" class="Panth\AdvancedSEO\Block\Adminhtml\GenericSaveButton"/>
            <button name="back" class="Panth\AdvancedSEO\Block\Adminhtml\GenericBackButton"/>
        </buttons>
        <namespace>panth_seo_filterrewrite_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>panth_seo_filterrewrite_form.panth_seo_filterrewrite_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="panth_seo_filterrewrite_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="panth_seo/filterrewrite/formSave"/>
        </settings>
        <dataProvider class="Panth\AdvancedSEO\Ui\Component\Form\DataProvider\FilterRewriteFormDataProvider" name="panth_seo_filterrewrite_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>rewrite_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Filter URL Rewrite</label>
        </settings>
        <field name="rewrite_id" formElement="input">
            <settings>
                <visible>false</visible>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="attribute_code" formElement="select" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Filter Attribute</label>
                <dataScope>attribute_code</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">Select the layered navigation attribute for this URL rewrite.</notice>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Panth\AdvancedSEO\Model\Config\Source\FilterableAttributes"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="option_id" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Option ID</label>
                <dataScope>option_id</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">The numeric option ID from the attribute's dropdown values. Find this in Catalog > Product Attributes > [Your Attribute] > Manage Options.</notice>
            </settings>
        </field>
        <field name="option_label" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Option Label (for reference)</label>
                <dataScope>option_label</dataScope>
                <notice translate="true">Human-readable label (e.g. "Red", "Size XL"). For your reference only — not used in URLs.</notice>
            </settings>
        </field>
        <field name="rewrite_slug" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType>
                <label translate="true">SEO-Friendly URL Slug</label>
                <dataScope>rewrite_slug</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">The URL-friendly slug that replaces the numeric filter value. Example: "red" instead of "color=123", making the URL /category/color-red.html. Use lowercase letters, numbers, and hyphens only.</notice>
            </settings>
        </field>
        <field name="store_id" formElement="select" sortOrder="50">
            <settings>
                <dataType>int</dataType>
                <label translate="true">Store View</label>
                <dataScope>store_id</dataScope>
                <notice translate="true">Select which store view this rewrite applies to. Use "All Store Views" for a global rewrite.</notice>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Store\Ui\Component\Listing\Column\Store\Options"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="is_active" formElement="select" sortOrder="60">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
