<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_seo_sitemap_listing.panth_seo_sitemap_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_seo_sitemap_listing_columns</spinner>
        <deps>
            <dep>panth_seo_sitemap_listing.panth_seo_sitemap_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Sitemap Profile</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_seo_sitemap_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">profile_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_seo_sitemap_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>profile_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected sitemap profiles?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="panth_seo/sitemap/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_seo_sitemap_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>profile_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="profile_id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <label translate="true">Name</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="store_id" class="Magento\Store\Ui\Component\Listing\Column\Store">
            <settings>
                <label translate="true">Store View</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="entity_types">
            <settings>
                <label translate="true">Entity Types</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Active</label>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="url_count">
            <settings>
                <label translate="true">URL Count</label>
                <dataType>number</dataType>
            </settings>
        </column>
        <column name="file_count">
            <settings>
                <label translate="true">File Count</label>
                <dataType>number</dataType>
            </settings>
        </column>
        <column name="last_generated_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <label translate="true">Last Generated</label>
                <dateFormat>MMM d, y, h:mm:ss a</dateFormat>
            </settings>
        </column>
        <column name="cron_enabled" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Cron</label>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\AdvancedSEO\Ui\Component\Listing\Column\SitemapActions">
            <settings>
                <indexField>profile_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
