<?php
/** @var \Panth\AdvancedSEO\Block\Adminhtml\Sitemap $block */

$files = $block->getSitemapFiles();
?>
<div class="panth-seo-sitemap-manager" style="padding: 20px;">
    <h2><?= $block->escapeHtml(__('SEO Sitemap Management')) ?></h2>

    <?php if (!empty($files)): ?>
        <table class="data-grid" style="margin: 20px 0;">
            <thead>
                <tr>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('File Path')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Size')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Last Modified')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($files as $file): ?>
                    <tr>
                        <td class="data-grid-td"><?= $block->escapeHtml((string)$file['path']) ?></td>
                        <td class="data-grid-td"><?= $block->escapeHtml(number_format((int)$file['size'] / 1024, 1) . ' KB') ?></td>
                        <td class="data-grid-td"><?= $block->escapeHtml((string)$file['modified']) ?></td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php else: ?>
        <div class="message message-notice" style="margin: 20px 0;">
            <span><?= $block->escapeHtml(__('No sitemap files found. Click "Rebuild Sitemap" to generate one.')) ?></span>
        </div>
    <?php endif; ?>

    <p style="margin: 15px 0; color: #666;">
        <?= $block->escapeHtml(__('Generate or rebuild the XML sitemap. This will crawl all products, categories, and CMS pages.')) ?>
    </p>

    <form method="post" action="<?= $block->escapeUrl($block->getGenerateUrl()) ?>">
        <?= $block->getBlockHtml('formkey') ?>
        <button type="submit" class="action-primary action-large">
            <span><?= $block->escapeHtml(__('Rebuild Sitemap')) ?></span>
        </button>
    </form>
</div>
